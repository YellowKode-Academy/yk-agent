# ══════════════════════════════════════════════════════════════
#  YellowKode Agent — Configuração / Configuration
#
#  COMO USAR / HOW TO USE:
#    cp .env.example .env
#    docker compose up -d --build
#    Acesse / Open: http://localhost:3000
# ══════════════════════════════════════════════════════════════

# ── Modelo de IA / AI Model ────────────────────────────────────
# Escolha conforme sua RAM disponível:
# Choose based on your available RAM:
#
#   gemma4:e2b  → ~1 GB   (mínimo — 4 GB RAM, CPU, mais rápido)
#   gemma4:e4b  → ~2.5 GB (recomendado ✅ — 8 GB RAM)
#   gemma4:12b  → ~7 GB   (alta qualidade — 8 GB+ RAM)
GEMMA_MODEL=gemma4:e4b

# ── Navegador do agente / Agent browser ───────────────────────
# Opções / Options: chromium | firefox | webkit
PLAYWRIGHT_BROWSER=chromium

# ── Banco de dados / Database ──────────────────────────────────
# Senha do PostgreSQL — pode manter o padrão em desenvolvimento
# PostgreSQL password — default is fine for local use
DB_PASSWORD=yk_agent_local

# ── Portas / Ports ─────────────────────────────────────────────
# Mude para 3001 se rodar yk-chat ao mesmo tempo / Change to 3001 if running yk-chat simultaneously
UI_PORT=3000
# Porta externa do Ollama / Ollama external port
# Mude para 11435 se rodar yk-chat ao mesmo tempo / Change to 11435 if running yk-chat simultaneously
OLLAMA_PORT=11434

# ── OpenClaw (motor do agente / agent engine) ──────────────────
OPENCLAW_VERSION=latest

# ── Produção com Traefik / Production with Traefik ─────────────
# Apenas para deploy com domínio próprio / Only for VPS deployment
DOMAIN=yourdomain.com
